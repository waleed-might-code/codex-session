# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
PEXO_CF_DOMAIN=
PEXO_CF_ZONE_ID=

# Default SSH server (seeded on first run)
DEFAULT_HOST=
DEFAULT_HOST_USER=root
DEFAULT_HOST_PASSWORD=

# Storage / Encryption
STORAGE_DIR=data
ENCRYPTION_KEY=          # auto-generated if blank

# Security
ALLOWED_PROJECT_ROOTS=/home,/Users,/root,/opt
MAX_OUTPUT_CHARS=3800
COMMAND_TIMEOUT=120
